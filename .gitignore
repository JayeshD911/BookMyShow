
# === Basic project artifacts to ignore ===
# Build output
/target/

# Compiled class files
*.class

# Logs
*.log

# Built packages (artifact files produced by builds)
*.jar
*.war
*.ear

# === Keep Maven wrapper files in the repo ===
# The maven wrapper files are recommended to be committed so contributors can build
!mvnw
!mvnw.cmd
!.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.properties

# === IDE / Editor directories (usually user-specific) ===
/.idea/
*.iws
*.iml
*.ipr

# Eclipse
.classpath
.project
.settings/

# VS Code
.vscode/

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# === OS files ===
.DS_Store
Thumbs.db

# === Temporary and cache files ===
*.tmp
tmp/

# Generated sources (commonly by build tools)
**/generated-sources/

# Local environment / secrets (do NOT commit secrets)
.env
.env.*
local.properties
secrets.properties
*.jks
*.keystore
*.p12

# Ignore a local secrets file used by application.properties import
# This is the file you should create locally with your DB username/password
application-secrets.properties

# If you intentionally store shared IDE settings, remove those entries from this file.
